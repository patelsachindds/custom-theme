{% comment %}
  Countdown snippet
  Expects settings: target_date (YYYY-MM-DD), target_time (HH:MM), title, alignment
{% endcomment %}

<div class="countdown-section countdown--{{ settings.alignment }}" data-target-date="{{ settings.target_date }}" data-target-time="{{ settings.target_time }}">
  {% if settings.title != blank %}
    <h2 class="countdown__title">{{ settings.title }}</h2>
  {% endif %}
  <div class="countdown__timer">
    <span class="countdown__days">00</span>d
    <span class="countdown__hours">00</span>h
    <span class="countdown__minutes">00</span>m
    <span class="countdown__seconds">00</span>s
  </div>
</div>

{% stylesheet %}
  .countdown-section {
    text-align: {{ settings.alignment }};
    margin: 1rem 0;
  }
  .countdown__title {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .countdown__timer {
    font-family: var(--font-family, sans-serif);
    font-size: 1.25rem;
    font-weight: 600;
    display: inline-flex;
    gap: 0.5rem;
  }
{% endstylesheet %}

{% javascript %}
  (function(){
    var container = document.currentScript.parentNode.querySelector('.countdown-section');
    if (!container) return;
    var targetDate = container.dataset.targetDate;
    console.log("targetDate", targetDate);
    var targetTime = container.dataset.targetTime || '00:00';
    var target = new Date(targetDate + 'T' + targetTime + ':00');
    function update(){
      var now = new Date();
      var diff = target - now;
      if (diff < 0) diff = 0;
      var days = Math.floor(diff / (1000*60*60*24));
      var hours = Math.floor((diff / (1000*60*60)) % 24);
      var minutes = Math.floor((diff / (1000*60)) % 60);
      var seconds = Math.floor((diff / 1000) % 60);
      container.querySelector('.countdown__days').textContent = String(days).padStart(2,'0');
      container.querySelector('.countdown__hours').textContent = String(hours).padStart(2,'0');
      container.querySelector('.countdown__minutes').textContent = String(minutes).padStart(2,'0');
      container.querySelector('.countdown__seconds').textContent = String(seconds).padStart(2,'0');
    }
    update();
    setInterval(update, 1000);
  })();
{% endjavascript %}

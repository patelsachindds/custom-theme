
{% render 'group_card', settings: block.settings %}

{% schema %}
{
  "name": "Group Card",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Image Settings"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Image (Desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_tablet",
      "label": "Image (Tablet/iPad)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image (Mobile)"
    },
    {
      "type": "header",
      "content": "Heading Settings"
    },
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading Text",
      "default": "Card Heading"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Heading Size (Desktop)",
      "default": 24
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Heading Size (Mobile)",
      "default": 18
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "richtext",
      "id": "content_text",
      "label": "Content Text",
      "default": "<p>Card content goes here.</p>"
    },
    {
      "type": "range",
      "id": "content_size_desktop",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Content Size (Desktop)",
      "default": 16
    },
    {
      "type": "range",
      "id": "content_size_mobile",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Content Size (Mobile)",
      "default": 14
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position (Desktop)",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "top"
    },
    {
      "type": "range",
      "id": "image_width",
      "min": 20,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Image Width (Desktop)",
      "default": 50,
      "info": "Applies when position is Left or Right",
      "visible_if": "{{ block.settings.image_position != 'top' }}"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    }
  ],
  "presets": [
    {
      "name": "Group Card",
      "category": "Layout"
    }
  ]
}
{% endschema %}

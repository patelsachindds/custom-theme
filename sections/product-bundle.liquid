{%- comment -%}
  Frequently Bought Together Bundle Section v1.0.3
  Renders a bundle widget reading from product.metafields.custom.bundle_products
{%- endcomment -%}

{%- liquid
  assign section_settings = section.settings
  assign bundle_products = product.metafields.custom.bundle_products.value
  assign has_bundle = false

  if bundle_products != blank
    assign bundle_size = bundle_products.size
    if bundle_size > 0
      assign has_bundle = true
    endif
  endif
-%}

{%- if has_bundle -%}
  <product-bundle-component class="product-bundle spacing-style color-{{ section_settings.color_scheme }}" style="{% render 'spacing-style', settings: section_settings %}" data-main-variant-id="{{ product.selected_or_first_available_variant.id }}">
    
    {%- if section_settings.heading != blank -%}
      <h3 class="product-bundle__heading">{{ section_settings.heading }}</h3>
    {%- endif -%}

    <div class="product-bundle__items">
      {%- comment -%} Main Product (Always included) {%- endcomment -%}
      <div class="product-bundle__item" data-variant-id="{{ product.selected_or_first_available_variant.id }}" data-price="{{ product.selected_or_first_available_variant.price }}">
        <div class="product-bundle__checkbox-wrapper">
          <input type="checkbox" id="bundle-item-main" checked disabled class="product-bundle__checkbox">
        </div>
        <div class="product-bundle__image-wrapper">
          {%- assign main_image = product.selected_or_first_available_variant.featured_image | default: product.featured_image -%}
          {%- if main_image -%}
            <img src="{{ main_image | image_url: width: 100 }}" alt="{{ product.title | escape }}" loading="lazy" width="50" height="50" class="product-bundle__image">
          {%- endif -%}
        </div>
        <div class="product-bundle__info">
          <p class="product-bundle__title"><strong>This item:</strong> {{ product.title }}</p>
          <div class="product-bundle__price">{% render 'price', product_resource: product, show_sale_price_first: true %}</div>
        </div>
      </div>

      {%- comment -%} Metafield Bundle Products {%- endcomment -%}
      {%- for bundle_product in bundle_products -%}
        {%- if bundle_product.available -%}
          {%- assign bundle_image = bundle_product.selected_or_first_available_variant.featured_image | default: bundle_product.featured_image -%}
          <div class="product-bundle__item" data-variant-id="{{ bundle_product.selected_or_first_available_variant.id }}" data-price="{{ bundle_product.selected_or_first_available_variant.price }}">
            <div class="product-bundle__checkbox-wrapper">
              <input type="checkbox" id="bundle-item-{{ bundle_product.id }}" class="product-bundle__checkbox" checked>
            </div>
            <div class="product-bundle__image-wrapper">
              {%- if bundle_image -%}
                <img src="{{ bundle_image | image_url: width: 100 }}" alt="{{ bundle_product.title | escape }}" loading="lazy" width="50" height="50" class="product-bundle__image">
              {%- endif -%}
            </div>
            <div class="product-bundle__info">
              <a href="{{ bundle_product.url }}" class="product-bundle__title link">{{ bundle_product.title }}</a>
              <div class="product-bundle__price">{% render 'price', product_resource: bundle_product, show_sale_price_first: true %}</div>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="product-bundle__summary">
      <div class="product-bundle__total">
        <span class="product-bundle__total-label">Total price:</span>
        <span class="product-bundle__total-price" data-bundle-total>Starting...</span>
      </div>
      <button type="button" class="button button--primary product-bundle__submit">
        Add Bundle to Cart
      </button>
      <div class="product-bundle__error hidden error-message"></div>
    </div>
  </product-bundle-component>

  <script src="{{ 'product-bundle.js' | asset_url }}" defer="defer"></script>

  {% style %}
    .product-bundle {
      border: 1px solid var(--color-border);
      border-radius: var(--style-border-radius-buttons-primary);
      padding: var(--padding-md);
      margin-block: var(--gap);
    }

    .product-bundle__heading {
      margin-top: 0;
      margin-bottom: var(--padding-sm);
      font-size: var(--font-size--md);
    }

    .product-bundle__items {
      display: flex;
      flex-direction: column;
      gap: var(--padding-sm);
      margin-bottom: var(--padding-md);
    }

    .product-bundle__item {
      display: flex;
      align-items: center;
      gap: var(--padding-sm);
    }

    .product-bundle__checkbox-wrapper {
      display: flex;
      align-items: center;
    }

    .product-bundle__checkbox {
      width: 18px;
      height: 18px;
    }

    .product-bundle__image-wrapper {
      width: 50px;
      height: 50px;
      flex-shrink: 0;
      border: 1px solid var(--color-border);
      border-radius: 4px;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--color-background-secondary);
    }

    .product-bundle__image {
      max-width: 100%;
      height: auto;
      object-fit: cover;
    }

    .product-bundle__info {
      flex-grow: 1;
      display: flex;
      flex-direction: column;
    }

    .product-bundle__title {
      margin: 0;
      font-size: var(--font-size--sm);
      line-height: 1.2;
    }

    .product-bundle__price {
      font-weight: 600;
      font-size: var(--font-size--sm);
      margin-top: 2px;
    }

    .product-bundle__summary {
      border-top: 1px solid var(--color-border);
      padding-top: var(--padding-sm);
    }

    .product-bundle__total {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: var(--padding-sm);
      font-weight: bold;
      font-size: var(--font-size--md);
    }

    .product-bundle__submit {
      width: 100%;
    }
  {% endstyle %}
{%- endif -%}

{% schema %}
{
  "name": "Frequently Bought Together",
  "tag": "section",
  "class": "section-bundle",
  "settings": [
    {
      "type": "paragraph",
      "content": "Requires a product metafield: custom.bundle_products"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Bought Together"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_block_start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_block_end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Frequently Bought Together"
    }
  ],
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  }
}
{% endschema %}
